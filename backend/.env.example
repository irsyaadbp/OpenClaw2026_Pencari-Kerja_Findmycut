     1|# =============================================
     2|# FindMyCut — Environment Variables
     3|# Copy to .env and fill in values
     4|# =============================================
     5|
     6|# === Server ===
     7|PORT=3000
     8|CORS_ORIGIN=http://localhost:5173
     9|
    10|# === Better Auth ===
    11|BETTER_AUTH_SECRET=change-me-to-random-32-chars-minimum
    12|BETTER_AUTH_URL=http://localhost:3000
    13|
    14|# === Neon PostgreSQL ===
    15|DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
    16|
    17|# === Main LLM — MiMo (Agent 2 & 3: tool calling) ===
    18|MAIN_LLM_BASE_URL=https://your-mimo-endpoint
    19|MAIN_LLM_API_KEY=your-mimo-api-key
    20|MAIN_LLM_MODEL=mimo-v2.5-pro
    21|
    22|# === Replicate (Vision + Image Gen) ===
    23|REPLICATE_API_TOKEN=your-replicate-api-token
    24|REPLICATE_VISION_MODEL=lucataco/moondream2
    25|REPLICATE_IMAGEGEN_MODEL=black-forest-labs/flux-2-pro
    26|
    27|# === Cloudflare R2 (image storage) ===
    28|R2_ACCOUNT_ID=your-cloudflare-account-id
    29|R2_ACCESS_KEY_ID=your-r2-access-key
    30|R2_SECRET_ACCESS_KEY=your-r2-secret-key
    31|R2_BUCKET_NAME=findmycut
    32|R2_PUBLIC_URL=https://your-bucket.r2.dev
    33|
    34|# === Google OAuth (optional — leave empty to disable) ===
    35|GOOGLE_CLIENT_ID=
    36|GOOGLE_CLIENT_SECRET=
    37|
    38|# === DOKU Payment ===
    39|DOKU_CLIENT_ID=your-doku-client-id
    40|DOKU_SECRET_KEY=your-doku-secret-key
    41|
    42|# === Google Maps — Barbershop Finder (optional, Agent 5) ===
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_RADIUS=5000

# === Logging ===
LOG_LEVEL=debug
NODE_ENV=development

# === Rate Limiting ===
    43|RATE_LIMIT_MAX_REQUESTS=10
    44|RATE_LIMIT_WINDOW_MS=60000
    45|