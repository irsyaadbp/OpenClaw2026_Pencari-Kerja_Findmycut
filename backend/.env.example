# =============================================
# FindMyCut — Environment Variables
# Copy to .env and fill in values
# =============================================

# === Server ===
PORT=3000
CORS_ORIGIN=http://localhost:5173

# === Better Auth ===
BETTER_AUTH_SECRET=change-me-to-random-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# === Neon PostgreSQL ===
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# === Main LLM — Zhipu GLM-4-Flash (Agent 2 & 3: tool calling) ===
MAIN_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MAIN_LLM_API_KEY=your-zhipu-api-key
MAIN_LLM_MODEL=glm-4-flash

# === Replicate (Vision + Image Gen) ===
REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_VISION_MODEL=lucataco/moondream2
REPLICATE_IMAGEGEN_MODEL=black-forest-labs/flux-schnell

# === Cloudflare R2 (image storage) ===
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=findmycut
R2_PUBLIC_URL=https://your-bucket.r2.dev

# === Google OAuth (optional — leave empty to disable) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === DOKU Payment ===
DOKU_CLIENT_ID=your-doku-client-id
DOKU_SECRET_KEY=your-doku-secret-key

# === Google Maps — Barbershop Finder (optional, Agent 5) ===
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_RADIUS=5000

# === Logging ===
LOG_LEVEL=debug
NODE_ENV=development

# === Rate Limiting ===
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000
