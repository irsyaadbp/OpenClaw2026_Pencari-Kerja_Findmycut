# =============================================
# FindMyCut — Environment Variables
# Copy to .env and fill in values
# =============================================

# === Server ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# === CORS & Frontend ===
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# === Better Auth ===
BETTER_AUTH_SECRET=change-me-to-random-32-chars-minimum!!
BETTER_AUTH_URL=http://localhost:3000
JWT_SECRET=change-me-to-random-32-chars-minimum!!

# === Neon PostgreSQL ===
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# === Main LLM — MiMo / Zhipu GLM (Agent 2, 3, 5: tool calling) ===
MAIN_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MAIN_LLM_API_KEY=your-zhipu-api-key
MAIN_LLM_MODEL=glm-4-flash

# === Replicate (Agent 4: Image Gen only) ===
REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_IMAGEGEN_MODEL=black-forest-labs/flux-schnell

# === Vision Model — Zhipu GLM-V5-Turbo (Agent 1: face/hair analysis, multimodal) ===
# Separate from MAIN_LLM because MiMo doesn't support image input
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VISION_API_KEY=your-zhipu-api-key
VISION_MODEL=glm-v5-turbo

# === Cloudflare R2 (image storage) ===
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=findmycut
R2_PUBLIC_URL=https://your-bucket.r2.dev

# === Google OAuth (optional — leave empty to disable) ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback/google

# === DOKU Payment (sandbox) ===
DOKU_CLIENT_ID=your-doku-client-id
DOKU_SECRET_KEY=your-doku-secret-key

# === Google Maps — Barbershop Finder (optional, Agent 5 hybrid) ===
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_RADIUS=5000

# === Rate Limiting ===
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000
